{
  "expo": {
    "name": "eec_campusboard",
    "slug": "eec_campusboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/4398.jpg",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/4398.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.eec.campusboard",
      "adaptiveIcon": {
        "foregroundImage": "./assets/4398.jpg",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "scheme": "eec_campusboard",
    "web": {
      "favicon": "./assets/4398.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "eec_campusboard needs access to your camera to scan QR codes."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {}
    }
  }
}